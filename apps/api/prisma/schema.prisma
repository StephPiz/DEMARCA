generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreStatus {
  active
  inactive
}

enum ProductType {
  watch
  bag
  perfume
  accessory
  vintage
  refurbished
  other
}

enum ProductStatus {
  active
  inactive
  archived
}

enum ChannelType {
  shopify
  idealo
  marketplace
  manual
  other
}

enum ChannelStatus {
  active
  inactive
}

enum WarehouseType {
  own
  external
  returns
}

enum WarehouseStatus {
  active
  inactive
}

enum LotSourceType {
  manual_init
  manual_receipt
  purchase_order
  return_restock
}

enum LotStatus {
  available
  held
  non_sellable
  repair
}

enum MovementType {
  lot_create
  receive_in
  manual_adjust
  sale_out
  return_in
  transfer_out
  transfer_in
}

enum EanAliasSource {
  manual
  marketplace
  idealo
  shopify
  other
}

enum ChannelListingStatus {
  active
  inactive
}

enum OrderStatus {
  pending
  paid
  packed
  shipped
  delivered
  returned
  cancelled
}

enum PaymentStatus {
  unpaid
  partially_paid
  paid
}

enum InvoiceStatus {
  draft
  issued
  cancelled
}

model HoldingCompany {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores Store[]

  @@map("holding_companies")
}

model Store {
  id                  String      @id @default(cuid())
  holdingId           String
  code                String
  name                String
  status              StoreStatus @default(active)
  description         String?
  logoUrl             String?
  themeColor          String?
  baseCurrencyCode    String      @default("EUR")
  invoicePrefix       String?
  invoiceSequenceNext Int         @default(1)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  holding HoldingCompany @relation(fields: [holdingId], references: [id])

  products         Product[]
  eanAliases       EanAlias[]
  warehouses       Warehouse[]
  channels         SalesChannel[]
  memberships      UserStoreMembership[]
  userPermissions  UserPermission[]
  inventoryLots    InventoryLot[]
  movements        InventoryMovement[]
  storeCurrencies  StoreCurrency[]
  fxRates          FxRate[]
  productOverrides ProductText[]
  customers        Customer[]
  salesOrders      SalesOrder[]
  salesOrderItems  SalesOrderItem[]
  payouts          Payout[]
  payoutMatches    PayoutOrderMatch[]
  invoices         Invoice[]

  @@unique([holdingId, code])
  @@map("stores")
}

model Product {
  id                  String        @id @default(cuid())
  storeId             String
  ean                 String
  sku                 String?
  type                ProductType   @default(other)
  brand               String
  model               String
  name                String
  status              ProductStatus @default(active)
  isInternalEan       Boolean       @default(false)
  internalDescription String?
  attributes          Json?
  mainImageUrl        String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  store      Store               @relation(fields: [storeId], references: [id])
  eanAliases EanAlias[]
  listings   ProductChannel[]
  texts      ProductText[]
  lots       InventoryLot[]
  movements  InventoryMovement[]
  orderItems SalesOrderItem[]

  @@unique([storeId, ean])
  @@index([storeId, brand, model])
  @@map("products")
}

model EanAlias {
  id        String         @id @default(cuid())
  storeId   String
  productId String
  ean       String
  source    EanAliasSource @default(manual)
  note      String?
  createdAt DateTime       @default(now())

  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, ean])
  @@index([productId])
  @@map("ean_aliases")
}

model SalesChannel {
  id          String        @id @default(cuid())
  storeId     String
  code        String
  name        String
  type        ChannelType
  status      ChannelStatus @default(active)
  feePercent  Decimal?      @db.Decimal(8, 4)
  cpaFixed    Decimal?      @db.Decimal(14, 2)
  payoutTerms String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  store    Store            @relation(fields: [storeId], references: [id])
  products ProductChannel[]
  texts    ProductText[]
  orders   SalesOrder[]
  payouts  Payout[]

  @@unique([storeId, code])
  @@map("sales_channels")
}

model ProductChannel {
  id                String               @id @default(cuid())
  productId         String
  channelId         String
  listingStatus     ChannelListingStatus @default(active)
  publicName        String?
  channelEan        String?
  listingUrl        String?
  priceOriginal     Decimal?             @db.Decimal(14, 2)
  priceCurrencyCode String?
  priceFxToEur      Decimal?             @db.Decimal(14, 6)
  priceEurFrozen    Decimal?             @db.Decimal(14, 2)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  channel SalesChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([productId, channelId])
  @@map("product_channels")
}

model ProductText {
  id          String   @id @default(cuid())
  storeId     String
  productId   String
  locale      String
  channelId   String?
  publicName  String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store   Store         @relation(fields: [storeId], references: [id])
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  channel SalesChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@unique([productId, locale, channelId])
  @@index([storeId, locale])
  @@map("product_texts")
}

model Warehouse {
  id        String          @id @default(cuid())
  storeId   String
  code      String
  name      String
  country   String?
  type      WarehouseType   @default(own)
  status    WarehouseStatus @default(active)
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  store     Store               @relation(fields: [storeId], references: [id])
  locations WarehouseLocation[]
  lots      InventoryLot[]
  movements InventoryMovement[]

  @@unique([storeId, code])
  @@map("warehouses")
}

model WarehouseLocation {
  id          String   @id @default(cuid())
  warehouseId String
  code        String
  name        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  lots      InventoryLot[]

  @@unique([warehouseId, code])
  @@map("warehouse_locations")
}

model InventoryLot {
  id                String        @id @default(cuid())
  storeId           String
  productId         String
  warehouseId       String
  locationId        String?
  lotCode           String
  sourceType        LotSourceType @default(manual_receipt)
  status            LotStatus     @default(available)
  supplierName      String?
  purchasedAt       DateTime?
  receivedAt        DateTime      @default(now())
  quantityReceived  Int
  quantityAvailable Int
  unitCostOriginal  Decimal       @db.Decimal(14, 4)
  costCurrencyCode  String
  fxToEur           Decimal       @db.Decimal(14, 6)
  unitCostEurFrozen Decimal       @db.Decimal(14, 4)
  note              String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  store     Store               @relation(fields: [storeId], references: [id])
  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse           @relation(fields: [warehouseId], references: [id])
  location  WarehouseLocation?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  movements InventoryMovement[]

  @@index([storeId, productId, receivedAt])
  @@index([warehouseId, productId])
  @@map("inventory_lots")
}

model InventoryMovement {
  id                String       @id @default(cuid())
  storeId           String
  productId         String
  lotId             String?
  warehouseId       String
  movementType      MovementType
  quantity          Int
  unitCostEurFrozen Decimal?     @db.Decimal(14, 4)
  referenceType     String?
  referenceId       String?
  reason            String?
  createdByUserId   String?
  createdAt         DateTime     @default(now())

  store     Store         @relation(fields: [storeId], references: [id])
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  lot       InventoryLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id])
  createdBy User?         @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([storeId, productId, createdAt])
  @@index([storeId, warehouseId, createdAt])
  @@map("inventory_movements")
}

model Currency {
  code      String   @id
  name      String
  symbol    String?
  createdAt DateTime @default(now())

  storeCurrencies StoreCurrency[]
  fxBaseRates     FxRate[]        @relation("FxBase")
  fxQuoteRates    FxRate[]        @relation("FxQuote")

  @@map("currencies")
}

model Customer {
  id        String   @id @default(cuid())
  storeId   String
  email     String?
  fullName  String?
  country   String?
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store  Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders SalesOrder[]

  @@index([storeId, email])
  @@map("customers")
}

model SalesOrder {
  id                   String        @id @default(cuid())
  storeId              String
  orderNumber          String
  platform             String
  sourceChannelId      String?
  sourceLabel          String?
  customerId           String?
  customerCountryCode  String?
  currencyCode         String
  grossAmountOriginal  Decimal       @db.Decimal(14, 2)
  grossFxToEur         Decimal       @db.Decimal(14, 6)
  grossAmountEurFrozen Decimal       @db.Decimal(14, 2)
  feesEur              Decimal       @default(0) @db.Decimal(14, 2)
  cpaEur               Decimal       @default(0) @db.Decimal(14, 2)
  shippingCostEur      Decimal       @default(0) @db.Decimal(14, 2)
  packagingCostEur     Decimal       @default(0) @db.Decimal(14, 2)
  returnCostEur        Decimal       @default(0) @db.Decimal(14, 2)
  cogsEur              Decimal       @default(0) @db.Decimal(14, 2)
  netProfitEur         Decimal       @default(0) @db.Decimal(14, 2)
  status               OrderStatus   @default(pending)
  paymentStatus        PaymentStatus @default(unpaid)
  orderedAt            DateTime      @default(now())
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  store         Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sourceChannel SalesChannel?      @relation(fields: [sourceChannelId], references: [id], onDelete: SetNull)
  customer      Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items         SalesOrderItem[]
  payoutMatches PayoutOrderMatch[]
  invoice       Invoice?

  @@unique([storeId, orderNumber])
  @@index([storeId, orderedAt])
  @@index([storeId, sourceChannelId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id                 String   @id @default(cuid())
  storeId            String
  orderId            String
  productId          String?
  productEan         String?
  title              String?
  quantity           Int
  unitPriceOriginal  Decimal  @db.Decimal(14, 2)
  fxToEur            Decimal  @db.Decimal(14, 6)
  unitPriceEurFrozen Decimal  @db.Decimal(14, 2)
  revenueEurFrozen   Decimal  @db.Decimal(14, 2)
  cogsEurFrozen      Decimal  @default(0) @db.Decimal(14, 2)
  createdAt          DateTime @default(now())

  store   Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([storeId, orderId])
  @@index([storeId, productId])
  @@map("sales_order_items")
}

model Payout {
  id              String   @id @default(cuid())
  storeId         String
  channelId       String?
  payoutRef       String
  payoutDate      DateTime
  currencyCode    String
  amountOriginal  Decimal  @db.Decimal(14, 2)
  fxToEur         Decimal  @db.Decimal(14, 6)
  amountEurFrozen Decimal  @db.Decimal(14, 2)
  feesEur         Decimal  @default(0) @db.Decimal(14, 2)
  adjustmentsEur  Decimal  @default(0) @db.Decimal(14, 2)
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store   Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  channel SalesChannel?      @relation(fields: [channelId], references: [id], onDelete: SetNull)
  matches PayoutOrderMatch[]

  @@unique([storeId, payoutRef])
  @@index([storeId, payoutDate])
  @@map("payouts")
}

model PayoutOrderMatch {
  id        String   @id @default(cuid())
  storeId   String
  payoutId  String
  orderId   String
  amountEur Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())

  store  Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  payout Payout     @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  order  SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([payoutId, orderId])
  @@index([storeId, orderId])
  @@map("payout_order_matches")
}

model Invoice {
  id             String        @id @default(cuid())
  storeId        String
  orderId        String        @unique
  invoiceNumber  String
  status         InvoiceStatus @default(issued)
  issuedAt       DateTime      @default(now())
  dueAt          DateTime?
  currencyCode   String
  subtotalEur    Decimal       @db.Decimal(14, 2)
  taxEur         Decimal       @default(0) @db.Decimal(14, 2)
  totalEur       Decimal       @db.Decimal(14, 2)
  billingName    String?
  billingAddress String?
  billingCountry String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  store Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([storeId, invoiceNumber])
  @@index([storeId, issuedAt])
  @@map("invoices")
}

model StoreCurrency {
  id           String   @id @default(cuid())
  storeId      String
  currencyCode String
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  currency Currency @relation(fields: [currencyCode], references: [code], onDelete: Restrict)

  @@unique([storeId, currencyCode])
  @@map("store_currencies")
}

model FxRate {
  id                String   @id @default(cuid())
  storeId           String
  baseCurrencyCode  String
  quoteCurrencyCode String
  rate              Decimal  @db.Decimal(18, 8)
  rateDate          DateTime
  source            String?
  createdAt         DateTime @default(now())

  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  baseCurrency  Currency @relation("FxBase", fields: [baseCurrencyCode], references: [code], onDelete: Restrict)
  quoteCurrency Currency @relation("FxQuote", fields: [quoteCurrencyCode], references: [code], onDelete: Restrict)

  @@unique([storeId, baseCurrencyCode, quoteCurrencyCode, rateDate])
  @@index([storeId, rateDate])
  @@map("fx_rates")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  fullName        String
  preferredLocale String   @default("es")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships      UserStoreMembership[]
  permissions      UserPermission[]
  refreshTokens    RefreshToken[]
  createdMovements InventoryMovement[]

  @@map("users")
}

model UserStoreMembership {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  roleKey   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId, roleKey])
  @@map("user_store_memberships")
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  description String?

  userPermissions UserPermission[]

  @@map("permissions")
}

model UserPermission {
  id           String   @id @default(cuid())
  userId       String
  storeId      String
  permissionId String
  granted      Boolean  @default(true)
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId, permissionId])
  @@index([storeId, userId])
  @@map("user_permissions")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("refresh_tokens")
}
