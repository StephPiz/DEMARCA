generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreStatus {
  active
  inactive
}

enum ProductType {
  standard
  vintage
  refurbished
}

enum ProductStatus {
  active
  inactive
  archived
}

enum ChannelType {
  shopify
  idealo
  marketplace
  manual
  other
}

enum ChannelStatus {
  active
  inactive
}

enum WarehouseType {
  own
  external
  returns
}

enum WarehouseStatus {
  active
  inactive
}

enum LotSourceType {
  manual_init
  manual_receipt
}

enum LotStatus {
  available
  held
  non_sellable
  repair
}

enum MovementType {
  lot_create
  manual_adjust
  sale_out
  return_in
  transfer_out
  transfer_in
}

enum EanAliasSource {
  manual
  marketplace
  worten
  idealo
  shopify
  other
}

model HoldingCompany {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores Store[]

  @@map("holding_companies")
}

model Store {
  id        String      @id @default(cuid())
  holdingId String
  code      String
  name      String
  status    StoreStatus @default(active)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  holding HoldingCompany @relation(fields: [holdingId], references: [id])

  products   Product[]
  warehouses Warehouse[]
  channels   SalesChannel[]

  @@unique([holdingId, code])
  @@map("stores")
}

model Product {
  id      String        @id @default(cuid())
  storeId String
  ean     String
  brand   String
  model   String
  type    ProductType   @default(standard)
  status  ProductStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, ean])
  @@map("products")
}

model Warehouse {
  id      String @id @default(cuid())
  storeId String
  code    String
  name    String

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, code])
  @@map("warehouses")
}

model SalesChannel {
  id      String @id @default(cuid())
  storeId String
  code    String
  name    String
  type    ChannelType

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, code])
  @@map("sales_channels")
}